{
  "name": "farmer-incentive-tracking",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev.js",
    "install:all": "npm --prefix backend install && cd frontend && flutter pub get",
    "backend:dev": "npm --prefix backend run dev",
    "frontend:dev": "cd frontend && flutter run -d web-server --web-port 3000",
    "build": "npm --prefix backend run build && cd frontend && flutter build web --release",
    "start": "npm --prefix backend run start"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0"
  }
}
